{
  "name": ".",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --host 0.0.0.0 --port 3001",
    "start:en": "docusaurus start --locale en --host 0.0.0.0 --port 3001",
    "start:de": "docusaurus start --locale de --host 0.0.0.0 --port 3001",
    "pid:3001": "lsof -nP -iTCP:3001 -sTCP:LISTEN",
    "stop:3001": "PIDS=$(lsof -tiTCP:3001 -sTCP:LISTEN); if [ -n \"$PIDS\" ]; then kill $PIDS && echo \"Stopped PID(s): $PIDS\"; else echo \"No listener on port 3001\"; fi",
    "restart:3001": "npm run stop:3001 && npm run start",
    "preview": "docusaurus build && docusaurus serve --host 0.0.0.0 --port 3001",
    "build": "docusaurus build",
    "import:manual": "node scripts/import-manual.mjs",
    "check:images": "node scripts/check-image-links.mjs",
    "translate:docs": "node scripts/translate-docs.mjs",
    "translate:ui": "node scripts/translate-ui.mjs",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@easyops-cn/docusaurus-search-local": "^0.55.2",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "he": "^1.2.0",
    "jsdom": "^29.1.1",
    "turndown": "^7.2.4",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0 <25"
  }
}
